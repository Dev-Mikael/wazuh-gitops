# Copy to .env only for local SealedSecret generation.
# Do not commit .env. In CI, add these as GitHub Actions secrets.

KUBESEAL_CERT=/tmp/sealed-secrets-public-cert.pem

WAZUH_API_USERNAME=wazuh-wui
WAZUH_API_PASSWORD=replace-with-long-random-password
WAZUH_AUTHD_PASS=replace-with-long-random-enrollment-password
WAZUH_CLUSTER_KEY=replace-with-32-character-cluster-key

DASHBOARD_USERNAME=kibanaserver
DASHBOARD_PASSWORD=replace-with-long-random-dashboard-password

INDEXER_USERNAME=admin
INDEXER_PASSWORD=replace-with-long-random-indexer-password

# Shuffle self-hosted deployment secrets.
SHUFFLE_OPENSEARCH_PASSWORD=replace-with-long-random-shuffle-opensearch-password
SHUFFLE_ENCRYPTION_MODIFIER=replace-with-long-random-shuffle-encryption-modifier
SHUFFLE_DEFAULT_USERNAME=soc-admin
SHUFFLE_DEFAULT_PASSWORD=replace-with-long-random-shuffle-admin-password
SHUFFLE_DEFAULT_APIKEY=replace-with-long-random-shuffle-api-key

# DFIR-IRIS self-hosted deployment secrets.
DFIR_IRIS_POSTGRES_PASSWORD=replace-with-long-random-postgres-password
DFIR_IRIS_POSTGRES_ADMIN_USER=raptor
DFIR_IRIS_POSTGRES_ADMIN_PASSWORD=replace-with-long-random-postgres-admin-password
DFIR_IRIS_SECRET_KEY=replace-with-long-random-iris-secret-key
DFIR_IRIS_SECURITY_PASSWORD_SALT=replace-with-long-random-iris-password-salt
DFIR_IRIS_ADMIN_PASSWORD=replace-with-long-random-iris-admin-password
DFIR_IRIS_ADMIN_API_KEY=replace-with-long-random-iris-admin-api-key

# Optional after the Shuffle workflow exists. If set, the sealing script creates
# wazuh-shuffle-webhook so Wazuh can forward high-severity alerts to Shuffle without
# committing the webhook URL to Git.
SHUFFLE_WEBHOOK_URL=http://shuffle-backend.shuffle.svc.cluster.local:5001/api/v1/hooks/replace-me

# These are used in Shuffle workflows, not directly by the Wazuh Kubernetes manifests.
DFIR_IRIS_URL=https://iris.internal.turog.example
DFIR_IRIS_API_KEY=replace-with-dfir-iris-api-key
OTX_API_KEY=replace-with-alienvault-otx-api-key
