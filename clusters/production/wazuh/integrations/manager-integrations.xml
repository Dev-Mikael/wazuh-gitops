<ossec_config>
  <!--
    Wazuh-to-AlienVault OTX integration used by this repository.

    This repo uses a custom integration script named custom-alienvault-secret. The
    script reads the real OTX API key from the Kubernetes Secret named
    wazuh-otx-api-key.

    The same block is applied in upstream/wazuh_managers/wazuh_conf/master.conf.
  -->
  <integration>
    <name>custom-alienvault-secret</name>
    <level>7</level>
    <alert_format>json</alert_format>
  </integration>

  <!--
    Shuffle and DFIR-IRIS are optional and intentionally not part of the active
    deployment path right now.
  -->
</ossec_config>
