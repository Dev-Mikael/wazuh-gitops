#!/var/ossec/framework/python/bin/python3
import json
import os
import sys
import urllib.error
import urllib.request
from pathlib import Path

HOOK_FILE = Path(os.environ.get("SHUFFLE_WEBHOOK_FILE", "/var/ossec/secrets/shuffle-webhook/hook_url"))


def log(message):
    print(f"custom-shuffle-secret: {message}", file=sys.stderr)


def main():
    if not HOOK_FILE.exists():
        log("Shuffle webhook secret is not mounted yet; skipping alert forwarding.")
        return 0

    hook_url = HOOK_FILE.read_text(encoding="utf-8").strip()
    if not hook_url or "replace-me" in hook_url:
        log("Shuffle webhook URL is empty or still a placeholder; skipping alert forwarding.")
        return 0

    if len(sys.argv) < 2 or not sys.argv[1]:
        log("No alert file argument received from Wazuh integrator.")
        return 0

    with open(sys.argv[1], encoding="utf-8") as alert_file:
        alert = json.load(alert_file)

    payload = {
        "source": "wazuh",
        "integration": "custom-shuffle-secret",
        "alert": alert,
    }

    request = urllib.request.Request(
        hook_url,
        data=json.dumps(payload).encode("utf-8"),
        headers={
            "Content-Type": "application/json",
            "User-Agent": "wazuh-custom-shuffle-secret",
        },
        method="POST",
    )

    try:
        with urllib.request.urlopen(request, timeout=10) as response:
            if response.status >= 300:
                log(f"Shuffle returned HTTP {response.status}.")
                return 1
    except urllib.error.URLError as exc:
        log(f"Failed to forward alert to Shuffle: {exc}.")
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
